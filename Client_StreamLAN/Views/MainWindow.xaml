<Window x:Class="Client_StreamLAN.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="StreamLAN Client" Height="780" Width="1060"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResize"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background"   Value="#FFFFFF"/>
            <Setter Property="Foreground"   Value="{StaticResource AutumnTextPrimaryBrush}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource AutumnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,5"/>
            <Setter Property="FontSize"     Value="12"/>
        </Style>
        <Style x:Key="CtrlButton" TargetType="Button" BasedOn="{StaticResource AutumnPrimaryButton}">
            <Setter Property="Padding"   Value="12,6"/>
            <Setter Property="FontSize"  Value="12"/>
            <Setter Property="Margin"    Value="0,0,6,0"/>
        </Style>
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"   Value="45"/>
            <Setter Property="Height"  Value="30"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor"  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AutumnAccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AutumnSecondaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Collapsible options expander -->
        <Style x:Key="OptionsExpander" TargetType="Expander">
            <Setter Property="Foreground"      Value="{StaticResource AutumnTextPrimaryBrush}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin"          Value="0,6,0,0"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource AutumnWindowBackground}"
            BorderBrush="{StaticResource AutumnAccentBrush}"
            BorderThickness="1" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="#2E1A11" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title bar -->
                <RowDefinition Height="*"/>     <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#3E2723" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="35">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="StreamLAN  —  Client" Foreground="White" FontSize="13"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="−" Click="MinimizeButton_Click" Style="{StaticResource WindowControlButton}"/>
                        <Button Content="□" Click="MaximizeButton_Click" Style="{StaticResource WindowControlButton}"/>
                        <Button Content="✕" Click="CloseButton_Click"   Style="{StaticResource CloseButton}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main content -->
            <Grid Grid.Row="1" Margin="16,10,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header: IP + Connection -->
                    <RowDefinition Height="Auto"/>  <!-- Controls panel -->
                    <RowDefinition Height="*"/>     <!-- Camera feed -->
                </Grid.RowDefinitions>

                <!-- ── Header ─────────────────────────────────────────── -->
                <Border Grid.Row="0" Style="{StaticResource AutumnCardPanel}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="StreamLAN Client" Style="{StaticResource AutumnTitleText}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="User: " Style="{StaticResource AutumnBodyText}"/>
                                <TextBlock x:Name="txtUserEmail" Text="TEST_MODE"
                                           Style="{StaticResource AutumnStatusText}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="Local IP: " Style="{StaticResource AutumnBodyText}"/>
                                <TextBlock x:Name="txtLocalIp" Text="" Style="{StaticResource AutumnStatusText}"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- Server connection -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Server Connection" Style="{StaticResource AutumnBodyText}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button x:Name="btnDiscover" Content="Discover" Click="BtnDiscover_Click"
                                        Style="{StaticResource CtrlButton}"/>
                                <ComboBox x:Name="cbServers" SelectionChanged="CbServers_SelectionChanged"
                                          Width="260" Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="txtManualIp" Width="170" Padding="8,5" Margin="0,0,6,0"
                                         Text="127.0.0.1" Background="White"
                                         BorderBrush="{StaticResource AutumnAccentBrush}" BorderThickness="1"/>
                                <Button Content="Connect" Click="BtnManualConnect_Click"
                                        Style="{StaticResource CtrlButton}"/>
                                <TextBlock x:Name="txtServerStatus" Text="Not connected"
                                           VerticalAlignment="Center" Style="{StaticResource AutumnBodyText}"
                                           Margin="6,0,0,0" Foreground="#94a3b8"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Controls Panel -->
                <Border Grid.Row="1" Style="{StaticResource AutumnCardPanel}">
                    <StackPanel>
                        <!-- Stream controls + Camera + Status -->
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnStart" Content="Start"  Click="BtnStart_Click"
                                    Style="{StaticResource CtrlButton}" IsEnabled="False"/>
                            <Button x:Name="btnPause" Content="Pause"  Click="BtnPause_Click"
                                    Style="{StaticResource CtrlButton}" IsEnabled="False"/>
                            <Button x:Name="btnStop"  Content="Stop"   Click="BtnStop_Click"
                                    Style="{StaticResource CtrlButton}" IsEnabled="False"/>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>

                            <TextBlock Text="Camera:" VerticalAlignment="Center"
                                       Style="{StaticResource AutumnBodyText}" Margin="0,0,6,0"/>
                            <ComboBox x:Name="cbCamera" SelectionChanged="CbCamera_SelectionChanged"
                                      Width="120" Style="{StaticResource ModernComboBox}" Margin="0,0,12,0"/>

                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>

                            <Ellipse x:Name="ellipseStatus" Width="9" Height="9"
                                     Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="txtStreamState" Text="Stopped"
                                       VerticalAlignment="Center" Style="{StaticResource AutumnBodyText}" Margin="0,0,16,0"/>
                            <TextBlock x:Name="txtFps" Text="FPS: --"
                                       VerticalAlignment="Center" Style="{StaticResource AutumnBodyText}" Margin="0,0,10,0"/>
                            <TextBlock x:Name="txtQuality" Text="Q: --%"
                                       VerticalAlignment="Center" Style="{StaticResource AutumnBodyText}"/>
                        </StackPanel>

                        <!-- Advanced options (collapsible) -->
                        <Expander Header="Advanced Options" IsExpanded="False"
                                  Style="{StaticResource OptionsExpander}">
                            <StackPanel Margin="4,8,0,0">
                                <!-- Resolution + Quality -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Resolution:" VerticalAlignment="Center"
                                               Style="{StaticResource AutumnBodyText}" Margin="0,0,6,0"/>
                                    <ComboBox x:Name="cbResolution" SelectionChanged="CbResolution_SelectionChanged"
                                              Width="110" Style="{StaticResource ModernComboBox}" Margin="0,0,16,0"/>

                                    <CheckBox x:Name="chkAdaptive" Content="Auto Quality"
                                              Checked="ChkAdaptive_Changed" Unchecked="ChkAdaptive_Changed"
                                              IsChecked="True" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Quality:" VerticalAlignment="Center"
                                               Style="{StaticResource AutumnBodyText}" Margin="0,0,6,0"/>
                                    <Slider x:Name="sliderQuality" Minimum="15" Maximum="85" Value="50"
                                            Width="100" VerticalAlignment="Center" IsEnabled="False"
                                            ValueChanged="SliderQuality_ValueChanged" Margin="0,0,4,0"/>
                                    <TextBlock x:Name="txtManualQuality" Text="50%"
                                               VerticalAlignment="Center" Style="{StaticResource AutumnBodyText}"/>
                                </StackPanel>

                                <!-- Image adjustments -->
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Brightness:" VerticalAlignment="Center"
                                               Style="{StaticResource AutumnBodyText}" Margin="0,0,6,0"/>
                                    <Slider x:Name="sliderBrightness" Minimum="-100" Maximum="100" Value="0"
                                            Width="90" VerticalAlignment="Center"
                                            ValueChanged="SliderBrightness_ValueChanged" Margin="0,0,16,0"/>

                                    <TextBlock Text="Contrast:" VerticalAlignment="Center"
                                               Style="{StaticResource AutumnBodyText}" Margin="0,0,6,0"/>
                                    <Slider x:Name="sliderContrast" Minimum="0.5" Maximum="2.0" Value="1.0"
                                            Width="90" VerticalAlignment="Center"
                                            ValueChanged="SliderContrast_ValueChanged" Margin="0,0,16,0"/>

                                    <CheckBox x:Name="chkFlipH" Content="Flip Horizontal"
                                              Checked="ChkFlipH_Changed" Unchecked="ChkFlipH_Changed"
                                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <CheckBox x:Name="chkFlipV" Content="Flip Vertical"
                                              Checked="ChkFlipV_Changed" Unchecked="ChkFlipV_Changed"
                                              VerticalAlignment="Center" Margin="0,0,16,0"/>
                                    <CheckBox x:Name="chkMicrophone" Content="Microphone"
                                              Checked="ChkMicrophone_Changed" Unchecked="ChkMicrophone_Changed"
                                              IsChecked="True" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- ── Camera Feed ─────────────────────────────────────── -->
                <Border Grid.Row="2" Style="{StaticResource AutumnCardPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Camera Preview"
                                   Style="{StaticResource AutumnHeaderText}" Margin="0,0,0,10"/>
                        <Border Grid.Row="1" Style="{StaticResource AutumnVideoContainer}">
                            <Image x:Name="imgCamera" Stretch="Uniform" Margin="5"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>